# HTTP server
PORT=3000
HOST=0.0.0.0
API_KEY=change-me-to-a-long-random-secret

# WhatsApp number this instance manages (e.g. 15551234567 — digits only, no +)
# Multiple numbers can exist in the same database; this selects the active one.
WHATSAPP_NUMBER=

# MySQL database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=baileys
DB_PASSWORD=change-me
DB_NAME=baileys

# Express JSON limit to support media payloads
JSON_LIMIT=25mb
